{
  "name": "@accedo/onscreen-debugger",
  "version": "1.0.1",
  "description": "On-screen debugger UI component for TV apps",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/OnScreenDebugger": {
      "types": "./dist/OnScreenDebugger.d.ts",
      "import": "./dist/OnScreenDebugger.js",
      "require": "./dist/OnScreenDebugger.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "@accedo:registry": "https://repo.cloud.accedo.tv/artifactory/api/npm/accedo-ps-npm-local/"
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@accedo/xdk-core": ">=4.0.0",
    "@accedo/xdk-virtual-key": ">=4.0.0",
    "react": ">=17.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "lodash": "^4.17.21",
    "mitt": "^3.0.1",
    "react-use-event-hook": "^0.9.6",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.178",
    "@types/node": "^25.6.0",
    "@types/react": "17.0.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "esbuild-sass-plugin": "^3.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.9",
    "postcss-modules": "^6.0.1",
    "postcss-selector-parser": "^7.1.1",
    "prettier": "^3.8.2",
    "sass": "^1.45.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
