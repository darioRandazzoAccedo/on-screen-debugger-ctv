{
  "name": "on-screen-debugger-ctv",
  "version": "1.0.0",
  "description": "On-screen debugger for TV applications",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/@types/react';const q='node_modules/@types/__react';if(fs.existsSync(p))fs.renameSync(p,q);\"",
    "prebuild": "node -e \"const fs=require('fs');const p='node_modules/@types/__react';const q='node_modules/@types/react';if(fs.existsSync(p))fs.renameSync(p,q);\"",
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs');const p='node_modules/@types/react';const q='node_modules/@types/__react';if(fs.existsSync(p))fs.renameSync(p,q);\"",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@accedo/xdk-core": ">=4",
    "@accedo/xdk-virtual-key": ">=4",
    "react": ">=17"
  },
  "dependencies": {
    "classnames": "^2.0.0",
    "mitt": "^3.0.0",
    "react-use-event-hook": "^0.9.6",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "esbuild-sass-plugin": "^2.16.0",
    "sass": "^1.69.0",
    "tsup": "^5.12.9",
    "typescript": "^4.9.5"
  },
  "engines": {
    "node": ">=14.16.1"
  }
}
